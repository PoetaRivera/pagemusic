# Variables de entorno del servidor
# Copia como .env y configura antes de correr

# Puerto (Railway lo asigna automáticamente)
PORT=4000

# URL del frontend (Railway la configura en producción)
FRONTEND_URL=http://localhost:5173

# REQUERIDO en producción — mínimo 32 caracteres, aleatorio
JWT_SECRET=cambia_esto_por_un_valor_seguro_de_al_menos_32_caracteres

# Credenciales del admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esto_en_produccion
